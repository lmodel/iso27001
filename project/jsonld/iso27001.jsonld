        "version",
        "party_type",
        "relationship",
        "requirements",
        "communication_needs",
        "contact_information"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/iso27001/InterestedParty",
      "@type": "ClassDefinition"
    },
