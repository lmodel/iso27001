{
  "name": "iso27001",
  "annotations": [
    {
      "tag": "standard_reference",
      "value": "ISO/IEC 27001:2022(E)"
    },
    {
      "tag": "amendment_reference",
      "value": "ISO/IEC 27001:2022/Amd. 1:2024(E)"
    },
    {
      "tag": "amendment_title",
      "value": "Climate action changes"
    },
    {
      "tag": "amendment_date",
      "value": "2024-02"
    },
    {
      "tag": "standard_title",
      "value": "Information security, cybersecurity and privacy protection -  Information security management systems - Requirements"
    },
    {
      "tag": "standard_edition",
      "value": "Third edition"
    },
    {
      "tag": "standard_date",
      "value": "2022-10"
    },
    {
      "tag": "normative_reference",
      "value": "ISO/IEC 27000 (vocabulary and overview)"
    },
    {
      "tag": "aligned_standard",
      "value": "ISO/IEC 27002:2022 (Annex A control guidance)"
    },
    {
      "tag": "risk_framework_alignment",
      "value": "ISO 31000:2018"
    },
    {
      "tag": "rights_notice",
      "value": "This project is licensed under Apache-2.0 for original code and schema structure. ISO/IEC standards text is owned by ISO and is not redistributed by this project license."
    },
