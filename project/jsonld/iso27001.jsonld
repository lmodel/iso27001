          "tag": "iso27001_clause",
          "value": "4.1",
          "@type": "Annotation"
        },
        {
          "tag": "iso27001_amendment",
          "value": "Amd. 1:2024",
          "@type": "Annotation"
        }
      ],
      "description": "Whether climate change has been determined to be a relevant issue for the organization's context, per Clause 4.1 as amended by Amd. 1:2024.",
