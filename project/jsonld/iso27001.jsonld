    {
      "name": "Organization",
      "definition_uri": "https://w3id.org/lmodel/iso27001/Organization",
      "annotations": [
        {
          "tag": "iso27001_clause",
          "value": "4.1",
          "@type": "Annotation"
        },
        {
          "tag": "iso27001_amendment",
          "value": "Amd. 1:2024",
          "@type": "Annotation"
        }
      ],
      "description": "The organization establishing and operating the ISMS. Captures context needed for Clause 4.1 (understanding the organization).",
      "comments": [
        "Context determination per 4.1 feeds into ISMS planning",
        "Climate change relevance determination added by Amd. 1:2024 to Clause 4.1",
        "Reference: ISO/IEC 27001:2022 Clause 4.1 and Amd. 1:2024. ISO/IEC standards text is copyright ISO - not reproduced here."
      ],
      "in_subset": [
        "isms_core"
      ],
      "from_schema": "https://w3id.org/lmodel/iso27001",
      "is_a": "NamedEntity",
      "slots": [
