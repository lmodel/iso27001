iso27001:risk_treatment_option a owl:ObjectProperty ;
    rdfs:label "risk_treatment_option" ;
    rdfs:range iso27001:RiskTreatmentOption ;
    skos:definition "Selected treatment option for the risk." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:risk_treatment_process a owl:ObjectProperty ;
    rdfs:label "risk_treatment_process" ;
    rdfs:range iso27001:RiskTreatmentProcess ;
    skos:definition "Reference to the risk treatment process." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:role_type a owl:DatatypeProperty ;
    rdfs:label "role_type" ;
    rdfs:range xsd:string ;
    skos:definition "Category of the role." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:root_cause_addressed a owl:DatatypeProperty ;
    rdfs:label "root_cause_addressed" ;
    rdfs:range xsd:string ;
    skos:definition "Root cause this action addresses." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:root_cause_analysis a owl:DatatypeProperty ;
    rdfs:label "root_cause_analysis" ;
    rdfs:range xsd:string ;
    skos:definition "Analysis of root cause." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:scope_statement a owl:DatatypeProperty ;
    rdfs:label "scope_statement" ;
    rdfs:range xsd:string ;
    skos:definition "Documented statement of ISMS scope per 4.3." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must be available as documented information" ;
    iso27001:iso27001_clause "4.3" .

iso27001:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:range xsd:string ;
    skos:definition "Severity rating." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:similar_nonconformities_check a owl:DatatypeProperty ;
    rdfs:label "similar_nonconformities_check" ;
    rdfs:range xsd:string ;
    skos:definition "Check for similar nonconformities elsewhere." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "10.2 b) 3)" .

iso27001:size_category a owl:DatatypeProperty ;
    rdfs:label "size_category" ;
    rdfs:range xsd:string ;
    skos:definition "Organization size classification." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:soa_template a owl:DatatypeProperty ;
    rdfs:label "soa_template" ;
    rdfs:range xsd:string ;
    skos:definition "Template used for Statement of Applicability." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:statement_of_applicability a owl:ObjectProperty ;
    rdfs:label "statement_of_applicability" ;
    rdfs:range iso27001:StatementOfApplicability ;
    skos:definition "Reference to the Statement of Applicability." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:subject a owl:DatatypeProperty ;
    rdfs:label "subject" ;
    rdfs:range xsd:string ;
    skos:definition "Subject of the communication." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:summary_findings a owl:DatatypeProperty ;
    rdfs:label "summary_findings" ;
    rdfs:range xsd:string ;
    skos:definition "Summary of assessment findings." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:target_completion_date a owl:DatatypeProperty ;
    rdfs:label "target_completion_date" ;
    rdfs:range xsd:date ;
    skos:definition "Target date for completing the action." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:target_implementation_date a owl:DatatypeProperty ;
    rdfs:label "target_implementation_date" ;
    rdfs:range xsd:date ;
    skos:definition "Target date for implementing the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:target_threshold a owl:DatatypeProperty ;
    rdfs:label "target_threshold" ;
    rdfs:range xsd:string ;
    skos:definition "Target threshold value." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:target_value a owl:DatatypeProperty ;
    rdfs:label "target_value" ;
    rdfs:range xsd:string ;
    skos:definition "Target value for the objective metric." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:threat_description a owl:DatatypeProperty ;
    rdfs:label "threat_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the threat exploiting the vulnerability." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:topic_area a owl:DatatypeProperty ;
    rdfs:label "topic_area" ;
    rdfs:range xsd:string ;
    skos:definition "The specific topic addressed by the policy." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:total_controls a owl:DatatypeProperty ;
    rdfs:label "total_controls" ;
    rdfs:range xsd:unsignedShort ;
    skos:definition "Total number of controls in scope." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:treatment_options_guidance a owl:DatatypeProperty ;
    rdfs:label "treatment_options_guidance" ;
    rdfs:range xsd:string ;
    skos:definition "Guidance on selecting treatment options." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:treatment_priority a owl:DatatypeProperty ;
    rdfs:label "treatment_priority" ;
    rdfs:range xsd:string ;
    skos:definition "Priority for treating this risk." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:trend a owl:DatatypeProperty ;
    rdfs:label "trend" ;
    rdfs:range xsd:string ;
    skos:definition "Current trend direction." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    skos:definition "Version identifier for the entity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Supports document control requirements per 7.5.3 e)" .

iso27001:vulnerability_description a owl:DatatypeProperty ;
    rdfs:label "vulnerability_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the vulnerability that could be exploited." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:Asset a owl:Class ;
    rdfs:label "Asset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:criticality ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:classification ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:asset_owner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:applicable_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:applicable_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:asset_custodian ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:related_risks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:asset_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:asset_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:criticality ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:criticality ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:location ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:classification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:asset_owner ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Risk ;
            owl:onProperty iso27001:related_risks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:asset_owner ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:classification ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:asset_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:asset_custodian ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:asset_custodian ],
        iso27001:NamedEntity ;
    skos:definition "An information asset or associated asset requiring protection, per Annex A control 5.9." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Inventory required per A.5.9",
        "Owners must be identified",
        "Subject to acceptable use rules per A.5.10" ;
    iso27001:annex_a_control "5.9" .

