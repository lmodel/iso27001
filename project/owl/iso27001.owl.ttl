    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Typically from ISO/IEC 27002:2022" .

iso27001:implementation_plan a owl:DatatypeProperty ;
    rdfs:label "implementation_plan" ;
    rdfs:range xsd:string ;
