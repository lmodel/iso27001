iso27001:outcome_assessment a owl:DatatypeProperty ;
    rdfs:label "outcome_assessment" ;
    rdfs:range xsd:string ;
    skos:definition "Assessment of actual outcomes." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:owner a owl:DatatypeProperty ;
    rdfs:label "owner" ;
    rdfs:range xsd:string ;
    skos:definition "Person accountable for the document content and maintenance." ;
