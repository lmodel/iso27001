            owl:allValuesFrom iso27001:CorrectiveAction ;
            owl:onProperty iso27001:corrective_actions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_assessment_process ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:monitoring_program ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Organization ;
            owl:onProperty iso27001:organization ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:interested_parties ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:communication_plan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:certification_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:certification_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:operational_procedures ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:certification_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:awareness_program ],
        iso27001:NamedEntity ;
    skos:definition "Top-level container representing an organization's complete ISMS per ISO 27001. Aggregates all components required for establishing, implementing, maintaining, and continually improving information security management." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per Clause 4.4, includes processes needed and their interactions",
        "Scope must be documented per 4.3",
        "This is the root entity for any ISMS conformance dataset" ;
    iso27001:iso27001_clause "4.4" ;
    iso27001:mandatory "true" .

xsd:duration a rdfs:Datatype .

xsd:positiveInteger a rdfs:Datatype .

iso27001:AuditFinding a owl:Class ;
    rdfs:label "AuditFinding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:root_cause_analysis ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:AuditFindingType ;
            owl:onProperty iso27001:finding_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:finding_description ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:closure_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:auditee_response ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:auditee_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:auditee_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:closure_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:objective_evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:recommended_action ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:closure_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:clause_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:recommended_action ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_implication ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:finding_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:closure_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:root_cause_analysis ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:objective_evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:root_cause_analysis ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:closure_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:clause_reference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:recommended_action ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:risk_implication ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:linked_corrective_action ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:linked_corrective_action ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:CorrectiveAction ;
            owl:onProperty iso27001:linked_corrective_action ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:closure_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_implication ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:finding_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:objective_evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:clause_reference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:finding_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:finding_description ],
        iso27001:NamedEntity ;
    skos:definition "A finding from an internal audit, including nonconformities, observations, and positive findings." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "9.2" .

<https://w3id.org/lmodel/iso-iec-27001/AuditFindingType#major_nonconformity> a owl:Class ;
    rdfs:label "major_nonconformity" ;
    rdfs:subClassOf iso27001:AuditFindingType ;
    skos:definition "Significant failure to fulfill a requirement that affects ISMS capability to achieve intended outcomes." .

<https://w3id.org/lmodel/iso-iec-27001/AuditFindingType#minor_nonconformity> a owl:Class ;
    rdfs:label "minor_nonconformity" ;
    rdfs:subClassOf iso27001:AuditFindingType ;
    skos:definition "Isolated lapse that does not significantly affect ISMS effectiveness." .

<https://w3id.org/lmodel/iso-iec-27001/AuditFindingType#observation> a owl:Class ;
    rdfs:label "observation" ;
    rdfs:subClassOf iso27001:AuditFindingType ;
    skos:altLabel "opportunity_for_improvement" ;
    skos:definition "Noted condition that could lead to nonconformity if not addressed." .

<https://w3id.org/lmodel/iso-iec-27001/AuditFindingType#positive_finding> a owl:Class ;
    rdfs:label "positive_finding" ;
    rdfs:subClassOf iso27001:AuditFindingType ;
    skos:definition "Evidence of effective implementation exceeding requirements." .

