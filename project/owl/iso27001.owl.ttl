    skos:definition "Date certification was achieved." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:certification_status a owl:DatatypeProperty ;
    rdfs:label "certification_status" ;
    rdfs:range xsd:string ;
    skos:definition "Current certification status." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:change_control_requirements a owl:DatatypeProperty ;
    rdfs:label "change_control_requirements" ;
    rdfs:range xsd:string ;
    skos:definition "Requirements for controlling changes." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:clause_reference a owl:DatatypeProperty ;
    rdfs:label "clause_reference" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to standard clause." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:closure_datetime a owl:DatatypeProperty ;
    rdfs:label "closure_datetime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date and time of incident closure." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:closure_evidence a owl:DatatypeProperty ;
    rdfs:label "closure_evidence" ;
    rdfs:range xsd:string ;
    skos:definition "Evidence supporting closure." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:closure_status a owl:DatatypeProperty ;
    rdfs:label "closure_status" ;
    rdfs:range xsd:string ;
    skos:definition "Status of finding closure." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:communication_date a owl:DatatypeProperty ;
    rdfs:label "communication_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the policy was communicated." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:communication_needs a owl:DatatypeProperty ;
    rdfs:label "communication_needs" ;
    rdfs:range xsd:string ;
    skos:definition "Communication requirements for this party." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:communication_plan a owl:ObjectProperty ;
    rdfs:label "communication_plan" ;
    rdfs:range iso27001:CommunicationPlan ;
    skos:definition "Reference to the communication plan." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:competency_assessment_date a owl:DatatypeProperty ;
    rdfs:label "competency_assessment_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date of last competency assessment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:completion_date a owl:DatatypeProperty ;
    rdfs:label "completion_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when implementation was completed." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:completion_tracking a owl:DatatypeProperty ;
    rdfs:label "completion_tracking" ;
    rdfs:range xsd:string ;
    skos:definition "How completion is tracked." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:consequences_addressed a owl:DatatypeProperty ;
    rdfs:label "consequences_addressed" ;
    rdfs:range xsd:string ;
    skos:definition "How consequences were dealt with." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "10.2 a) 2)" .

iso27001:contact_information a owl:DatatypeProperty ;
    rdfs:label "contact_information" ;
    rdfs:range xsd:string ;
    skos:definition "Contact details for the party." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:context_changes a owl:DatatypeProperty ;
    rdfs:label "context_changes" ;
    rdfs:range xsd:string ;
    skos:definition "Changes in context since last review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "9.3.2 b)" .

iso27001:control_category a owl:ObjectProperty ;
    rdfs:label "control_category" ;
    rdfs:range iso27001:ControlCategory ;
    skos:definition "Domain category of the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_id a owl:DatatypeProperty ;
    rdfs:label "control_id" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[5-8]\\.[0-9]{1,2}$" ] ) ] ) ] ;
    skos:definition "Control identifier from Annex A (e.g., 5.1, 8.24)." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Format matches Annex A numbering" .

iso27001:control_owner a owl:DatatypeProperty ;
    rdfs:label "control_owner" ;
    rdfs:range xsd:string ;
    skos:definition "Person responsible for the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_selection_criteria a owl:DatatypeProperty ;
    rdfs:label "control_selection_criteria" ;
    rdfs:range xsd:string ;
    skos:definition "Criteria for selecting controls." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_text a owl:DatatypeProperty ;
    rdfs:label "control_text" ;
    rdfs:range xsd:string ;
    skos:definition "Full text of the control requirement." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_title a owl:DatatypeProperty ;
    rdfs:label "control_title" ;
    rdfs:range xsd:string ;
    skos:definition "Title of the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:cost a owl:DatatypeProperty ;
    rdfs:label "cost" ;
    rdfs:range xsd:string ;
    skos:definition "Cost of the resource." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:created_date a owl:DatatypeProperty ;
    rdfs:label "created_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the entity was created." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:criticality a owl:DatatypeProperty ;
    rdfs:label "criticality" ;
    rdfs:range xsd:string ;
    skos:definition "Criticality rating of the asset." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:delegation_rules a owl:DatatypeProperty ;
    rdfs:label "delegation_rules" ;
    rdfs:range xsd:string ;
    skos:definition "Rules for delegating responsibilities." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:definition "Detailed description of the entity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Should provide sufficient detail for understanding without external reference" .

iso27001:detected_by a owl:DatatypeProperty ;
    rdfs:label "detected_by" ;
    rdfs:range xsd:string ;
    skos:definition "Person or process that detected the nonconformity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:detection_date a owl:DatatypeProperty ;
    rdfs:label "detection_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date the nonconformity was detected." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:detection_method a owl:DatatypeProperty ;
    rdfs:label "detection_method" ;
    rdfs:range xsd:string ;
    skos:definition "How the incident was detected." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:document_reference a owl:DatatypeProperty ;
    rdfs:label "document_reference" ;
    rdfs:range xsd:string ;
    skos:definition "Unique reference number for document control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per 7.5.2 a) identification and description" .

iso27001:document_type a owl:ObjectProperty ;
    rdfs:label "document_type" ;
    rdfs:range iso27001:DocumentType ;
    skos:definition "Classification of the documented information." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:effective_date a owl:DatatypeProperty ;
    rdfs:label "effective_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the document becomes effective." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:effectiveness_criteria a owl:DatatypeProperty ;
    rdfs:label "effectiveness_criteria" ;
    rdfs:range xsd:string ;
    skos:definition "Criteria for evaluating effectiveness." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:effectiveness_measures a owl:DatatypeProperty ;
    rdfs:label "effectiveness_measures" ;
    rdfs:range xsd:string ;
    skos:definition "How effectiveness is measured." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:effectiveness_rating a owl:DatatypeProperty ;
    rdfs:label "effectiveness_rating" ;
    rdfs:range xsd:string ;
    skos:definition "Rating of control effectiveness." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:effectiveness_review_date a owl:DatatypeProperty ;
    rdfs:label "effectiveness_review_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date effectiveness was reviewed." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "10.2 d)" .

iso27001:effectiveness_verified a owl:DatatypeProperty ;
    rdfs:label "effectiveness_verified" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether effectiveness was verified." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:employee_count a owl:DatatypeProperty ;
    rdfs:label "employee_count" ;
    rdfs:range xsd:positiveInteger ;
