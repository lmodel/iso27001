iso27001:likelihood_scale a owl:DatatypeProperty ;
    rdfs:label "likelihood_scale" ;
    rdfs:range xsd:string ;
    skos:definition "Scale used for likelihood rating." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:linked_corrective_action a owl:ObjectProperty ;
