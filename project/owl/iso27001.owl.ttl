    rdfs:range xsd:string ;
    skos:definition "Legal registered name of the organization." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:lessons_learned a owl:DatatypeProperty ;
    rdfs:label "lessons_learned" ;
    rdfs:range xsd:string ;
    skos:definition "Lessons learned from the incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
