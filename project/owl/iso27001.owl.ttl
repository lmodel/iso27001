    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:event_datetime a owl:DatatypeProperty ;
    rdfs:label "event_datetime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date and time of the event." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:event_description a owl:DatatypeProperty ;
    rdfs:label "event_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the event." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:exclusion_justification a owl:DatatypeProperty ;
    rdfs:label "exclusion_justification" ;
    rdfs:range xsd:string ;
    skos:definition "Justification for excluding the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "6.1.3 d)" .

iso27001:expected_benefit a owl:DatatypeProperty ;
    rdfs:label "expected_benefit" ;
    rdfs:range xsd:string ;
    skos:definition "Expected benefit from implementation." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:finding_description a owl:DatatypeProperty ;
    rdfs:label "finding_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the finding." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:finding_type a owl:ObjectProperty ;
    rdfs:label "finding_type" ;
    rdfs:range iso27001:AuditFindingType ;
    skos:definition "Type of audit finding." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Unique identifier for the entity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Should use consistent URI/CURIE format across the dataset" .

iso27001:identification_date a owl:DatatypeProperty ;
    rdfs:label "identification_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date identified." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:identified_by a owl:DatatypeProperty ;
    rdfs:label "identified_by" ;
    rdfs:range xsd:string ;
    skos:definition "Person who identified it." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:impact a owl:ObjectProperty ;
    rdfs:label "impact" ;
    rdfs:range iso27001:ImpactRating ;
    skos:definition "Assessed impact if risk materializes." ;
