iso27001:last_review_date a owl:DatatypeProperty ;
    rdfs:label "last_review_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date of last review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:last_test_date a owl:DatatypeProperty ;
