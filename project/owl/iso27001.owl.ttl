iso27001:linked_incident a owl:ObjectProperty ;
    rdfs:label "linked_incident" ;
    rdfs:range iso27001:InformationSecurityIncident ;
    skos:definition "Linked incident if categorized." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:linked_nonconformity a owl:ObjectProperty ;
    rdfs:label "linked_nonconformity" ;
    rdfs:range iso27001:Nonconformity ;
