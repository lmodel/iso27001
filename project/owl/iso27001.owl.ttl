iso27001:impact_scale a owl:DatatypeProperty ;
    rdfs:label "impact_scale" ;
    rdfs:range xsd:string ;
    skos:definition "Scale used for impact rating." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:implementation_date a owl:DatatypeProperty ;
    rdfs:label "implementation_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date the control was implemented." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:implementation_evidence a owl:DatatypeProperty ;
    rdfs:label "implementation_evidence" ;
    rdfs:range xsd:string ;
    skos:definition "Evidence of control implementation." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:implementation_guidance a owl:DatatypeProperty ;
    rdfs:label "implementation_guidance" ;
    rdfs:range xsd:string ;
