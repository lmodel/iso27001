    skos:definition "A security control from Annex A of ISO/IEC 27001:2022, derived from ISO/IEC 27002:2022. Represents a measure that modifies risk." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "93 controls organized in four domains (organizational, people, physical, technological)",
        "Controls are referenced in risk treatment and SoA",
        "Per NOTE 1 in 6.1.3, organizations can design controls or identify from any source" ;
    iso27001:annex_reference "Annex A" ;
    iso27001:iso27001_clause "6.1.3" .

