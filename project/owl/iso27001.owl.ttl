    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:implementation_timeline a owl:DatatypeProperty ;
    rdfs:label "implementation_timeline" ;
    rdfs:range xsd:string ;
    skos:definition "Timeline for implementation." ;
