    skos:note "Effectiveness must be reviewed",
        "May require ISMS changes",
        "Must be appropriate to effects of nonconformities" ;
    iso27001:iso27001_clause "10.2" .

iso27001:RiskTreatmentOption a owl:Class ;
    rdfs:label "RiskTreatmentOption" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#modify> <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#accept> <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#avoid> <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#share> ) ;
    skos:definition "Standard risk treatment options per ISO 31000 and ISO 27005." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#accept>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#avoid>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#modify>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#share> ;
    iso27001:iso31000_reference "Clause 6.5" .

iso27001:actual_completion_date a owl:DatatypeProperty ;
    rdfs:label "actual_completion_date" ;
    rdfs:range xsd:date ;
    skos:definition "Actual date the action was completed." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:affected_assets a owl:ObjectProperty ;
    rdfs:label "affected_assets" ;
    rdfs:range iso27001:Asset ;
    skos:definition "Assets affected by this risk or incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:approved_by a owl:DatatypeProperty ;
    rdfs:label "approved_by" ;
    rdfs:range xsd:string ;
    skos:definition "Person who approved the document." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per 7.5.2 c) review and approval" .

iso27001:approved_date a owl:DatatypeProperty ;
    rdfs:label "approved_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the document was approved." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:classification a owl:DatatypeProperty ;
    rdfs:label "classification" ;
    rdfs:range xsd:string ;
    skos:definition "Information classification level." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per A.5.12, classification based on confidentiality, integrity, availability" .

iso27001:closure_date a owl:DatatypeProperty ;
    rdfs:label "closure_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date the finding was closed." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_reference a owl:ObjectProperty ;
    rdfs:label "control_reference" ;
    rdfs:range iso27001:SecurityControl ;
    skos:definition "Reference to the control (e.g., A.5.1)." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:current_value a owl:DatatypeProperty ;
    rdfs:label "current_value" ;
    rdfs:range xsd:string ;
    skos:definition "Current measured value." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:frequency a owl:DatatypeProperty ;
    rdfs:label "frequency" ;
    rdfs:range xsd:string ;
    skos:definition "Frequency of the activity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:measurement_frequency a owl:DatatypeProperty ;
    rdfs:label "measurement_frequency" ;
    rdfs:range xsd:string ;
    skos:definition "How often measurement is performed." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:measurement_method a owl:DatatypeProperty ;
    rdfs:label "measurement_method" ;
    rdfs:range xsd:string ;
    skos:definition "Method used to measure the metric." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:related_controls a owl:ObjectProperty ;
    rdfs:label "related_controls" ;
    rdfs:range iso27001:SecurityControl ;
    skos:definition "Other controls related to this one." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:resources_required a owl:DatatypeProperty ;
    rdfs:label "resources_required" ;
    rdfs:range xsd:string ;
    skos:definition "Resources required for implementation." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:responsible_role a owl:ObjectProperty ;
    rdfs:label "responsible_role" ;
    rdfs:range iso27001:Role ;
    skos:definition "Role responsible for the objective or control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:review_date a owl:DatatypeProperty ;
    rdfs:label "review_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the document is due for review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:root_cause a owl:DatatypeProperty ;
    rdfs:label "root_cause" ;
    rdfs:range xsd:string ;
    skos:definition "Root cause of the nonconformity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "10.2 b) 2)" .

iso27001:target_audience a owl:DatatypeProperty ;
    rdfs:label "target_audience" ;
    rdfs:range xsd:string ;
    skos:definition "Intended audience for the policy or document." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:target_date a owl:DatatypeProperty ;
    rdfs:label "target_date" ;
    rdfs:range xsd:date ;
    skos:definition "Target date for achieving the objective." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:ImpactRating a owl:Class ;
    rdfs:label "ImpactRating" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#negligible> <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#minor> <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#moderate> <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#major> <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#severe> ) ;
    skos:definition "Qualitative impact scale for risk assessment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#major>,
        <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#minor>,
        <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#moderate>,
        <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#negligible>,
        <https://w3id.org/lmodel/iso-iec-27001/ImpactRating#severe> .

iso27001:LikelihoodRating a owl:Class ;
    rdfs:label "LikelihoodRating" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#rare> <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#unlikely> <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#possible> <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#likely> <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#almost_certain> ) ;
    skos:definition "Qualitative likelihood scale for risk assessment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#almost_certain>,
        <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#likely>,
        <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#possible>,
        <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#rare>,
        <https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#unlikely> .

iso27001:Risk a owl:Class ;
    rdfs:label "Risk" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:residual_risk_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:threat_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:existing_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:affected_assets ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:inherent_risk_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:risk_owner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:threat_description ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:LikelihoodRating ;
            owl:onProperty iso27001:likelihood ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:RiskLevel ;
            owl:onProperty iso27001:residual_risk_level ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:inherent_risk_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_owner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:vulnerability_description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_owner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_treatment_option ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:treatment_priority ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:likelihood ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:vulnerability_description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:threat_description ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Asset ;
            owl:onProperty iso27001:affected_assets ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:related_treatment_plan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:treatment_priority ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:affected_cia_properties ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:affected_cia_properties ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:related_treatment_plan ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:treatment_priority ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:RiskLevel ;
            owl:onProperty iso27001:inherent_risk_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:RiskTreatmentOption ;
            owl:onProperty iso27001:risk_treatment_option ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:risk_source ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:ImpactRating ;
            owl:onProperty iso27001:impact ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:residual_risk_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:RiskTreatmentPlan ;
            owl:onProperty iso27001:related_treatment_plan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_treatment_option ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:vulnerability_description ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:existing_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:impact ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:impact ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:likelihood ],
        iso27001:NamedEntity ;
    skos:definition "An identified information security risk associated with loss of confidentiality, integrity, or availability per 6.1.2 c)." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Analyzed for consequences and likelihood per 6.1.2 d)",
        "Evaluated against criteria and prioritized per 6.1.2 e)",
        "Must identify risk owners per 6.1.2 c) 2)" ;
    iso27001:iso27001_clause "6.1.2" .

iso27001:Role a owl:Class ;
    rdfs:label "Role" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:responsibilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:delegation_rules ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:reporting_line ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:authorities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:reporting_line ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:role_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:delegation_rules ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:authorities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:responsibilities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assigned_to ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:role_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:assigned_to ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:reporting_line ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:role_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:accountability ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:delegation_rules ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:accountability ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:accountability ],
        iso27001:NamedEntity ;
    skos:definition "An information security role with defined responsibilities and authorities per Clause 5.3." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Top management must assign responsibility for ISMS conformance",
        "Top management must assign responsibility for ISMS performance reporting" ;
    iso27001:iso27001_clause "5.3" .

xsd:unsignedShort a rdfs:Datatype .

iso27001:DocumentType a owl:Class ;
    rdfs:label "DocumentType" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/DocumentType#policy> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#procedure> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#standard> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#guideline> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#record> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#plan> <https://w3id.org/lmodel/iso-iec-27001/DocumentType#report> ) ;
    skos:definition "Categories of documented information required or recommended by ISO 27001." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/DocumentType#guideline>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#plan>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#policy>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#procedure>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#record>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#report>,
        <https://w3id.org/lmodel/iso-iec-27001/DocumentType#standard> .

iso27001:ImplementationStatus a owl:Class ;
    rdfs:label "ImplementationStatus" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_started> <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#planned> <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#in_progress> <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#implemented> <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_applicable> ) ;
    skos:definition "Lifecycle status of a security control, used in Statement of Applicability and control tracking." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#implemented>,
        <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#in_progress>,
        <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_applicable>,
        <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_started>,
        <https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#planned> .

iso27001:RiskLevel a owl:Class ;
    rdfs:label "RiskLevel" ;
    owl:unionOf ( <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#very_low> <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#low> <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#medium> <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#high> <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#critical> ) ;
    skos:definition "Qualitative risk rating derived from likelihood × impact analysis." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    linkml:permissible_values <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#critical>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#high>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#low>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#medium>,
        <https://w3id.org/lmodel/iso-iec-27001/RiskLevel#very_low> .

iso27001:implementation_status a owl:ObjectProperty ;
    rdfs:label "implementation_status" ;
    rdfs:range iso27001:ImplementationStatus ;
    skos:definition "Current implementation status." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:responsible_party a owl:DatatypeProperty ;
    rdfs:label "responsible_party" ;
    rdfs:range xsd:string ;
    skos:definition "Party responsible for the activity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:range xsd:string ;
    skos:definition "Current status of the document or entity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Examples include draft, approved, active, superseded, archived" .

iso27001:NamedEntity a owl:Class ;
    rdfs:label "NamedEntity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty iso27001:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:created_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:created_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:modified_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:created_date ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty iso27001:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:modified_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:modified_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty iso27001:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:id ] ;
    skos:definition "Abstract base class for all entities with an identifier, name, and description. Provides common identification and documentation slots." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "All concrete classes should inherit from this or a subclass",
        "Ensures consistent identification across the schema" .

iso27001:SecurityControl a owl:Class ;
    rdfs:label "SecurityControl" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:last_test_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:effectiveness_rating ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:control_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_title ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:related_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:applicable_threats ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:last_test_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:effectiveness_rating ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:ImplementationStatus ;
            owl:onProperty iso27001:implementation_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
