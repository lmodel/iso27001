    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per 6.2 b) objectives shall be measurable if practicable" .

iso27001:metric_description a owl:DatatypeProperty ;
    rdfs:label "metric_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of what is measured." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:metric_name a owl:DatatypeProperty ;
    rdfs:label "metric_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the metric." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:modified_date a owl:DatatypeProperty ;
    rdfs:label "modified_date" ;
    rdfs:range xsd:date ;
    skos:definition "Date when the entity was last modified." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:monitoring_program a owl:ObjectProperty ;
    rdfs:label "monitoring_program" ;
    rdfs:range iso27001:MonitoringProgram ;
    skos:definition "Reference to the monitoring program." ;
