<https://w3id.org/lmodel/iso-iec-27001/ControlCategory#organizational> a owl:Class ;
    rdfs:label "organizational" ;
    rdfs:subClassOf iso27001:ControlCategory ;
    skos:definition "Organizational controls (Annex A.5) — policies, roles, asset management, access control, supplier relationships, incident management, compliance." ;
    iso27001:annex_clause "5" ;
    iso27001:control_count "37" .

<https://w3id.org/lmodel/iso-iec-27001/ControlCategory#people> a owl:Class ;
    rdfs:label "people" ;
    rdfs:subClassOf iso27001:ControlCategory ;
    skos:definition "People controls (Annex A.6) — screening, employment terms, awareness, disciplinary process, termination responsibilities, remote working." ;
    iso27001:annex_clause "6" ;
    iso27001:control_count "8" .

<https://w3id.org/lmodel/iso-iec-27001/ControlCategory#physical> a owl:Class ;
    rdfs:label "physical" ;
    rdfs:subClassOf iso27001:ControlCategory ;
    skos:definition "Physical controls (Annex A.7) — perimeters, entry controls, equipment protection, secure areas, media handling, cabling, maintenance." ;
    iso27001:annex_clause "7" ;
    iso27001:control_count "14" .

<https://w3id.org/lmodel/iso-iec-27001/ControlCategory#technological> a owl:Class ;
    rdfs:label "technological" ;
    rdfs:subClassOf iso27001:ControlCategory ;
    skos:definition "Technological controls (Annex A.8) — endpoint security, access restrictions, authentication, malware protection, logging, cryptography, secure development." ;
    iso27001:annex_clause "8" ;
    iso27001:control_count "34" .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#guideline> a owl:Class ;
    rdfs:label "guideline" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Recommended practices that support policies and procedures." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#plan> a owl:Class ;
    rdfs:label "plan" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Documented approach for achieving objectives (e.g., risk treatment plan)." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#policy> a owl:Class ;
    rdfs:label "policy" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "High-level statement of intent and direction (e.g., IS policy per 5.2)." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#procedure> a owl:Class ;
    rdfs:label "procedure" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Documented steps for performing activities consistently." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#record> a owl:Class ;
    rdfs:label "record" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Evidence of activities performed or results achieved." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#report> a owl:Class ;
    rdfs:label "report" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Formal output of assessment, audit, or review activities." .

<https://w3id.org/lmodel/iso-iec-27001/DocumentType#standard> a owl:Class ;
    rdfs:label "standard" ;
    rdfs:subClassOf iso27001:DocumentType ;
    skos:definition "Mandatory requirements for specific technologies or processes." .

<https://w3id.org/lmodel/iso-iec-27001/ImpactRating#major> a owl:Class ;
    rdfs:label "major" ;
    rdfs:subClassOf iso27001:ImpactRating ;
    skos:definition "Serious impact on objectives, reputation, or compliance." ;
    iso27001:numeric_value "4" .

<https://w3id.org/lmodel/iso-iec-27001/ImpactRating#minor> a owl:Class ;
    rdfs:label "minor" ;
    rdfs:subClassOf iso27001:ImpactRating ;
    skos:definition "Limited impact, easily absorbed by normal operations." ;
    iso27001:numeric_value "2" .

<https://w3id.org/lmodel/iso-iec-27001/ImpactRating#moderate> a owl:Class ;
    rdfs:label "moderate" ;
    rdfs:subClassOf iso27001:ImpactRating ;
    skos:definition "Noticeable impact requiring management intervention." ;
    iso27001:numeric_value "3" .

<https://w3id.org/lmodel/iso-iec-27001/ImpactRating#negligible> a owl:Class ;
    rdfs:label "negligible" ;
    rdfs:subClassOf iso27001:ImpactRating ;
    skos:definition "No significant impact on operations or objectives." ;
    iso27001:numeric_value "1" .

<https://w3id.org/lmodel/iso-iec-27001/ImpactRating#severe> a owl:Class ;
    rdfs:label "severe" ;
    rdfs:subClassOf iso27001:ImpactRating ;
    skos:definition "Catastrophic impact threatening organizational viability." ;
    iso27001:numeric_value "5" .

<https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#implemented> a owl:Class ;
    rdfs:label "implemented" ;
    rdfs:subClassOf iso27001:ImplementationStatus ;
    skos:definition "Control fully implemented and operational." .

<https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#in_progress> a owl:Class ;
    rdfs:label "in_progress" ;
    rdfs:subClassOf iso27001:ImplementationStatus ;
    skos:definition "Implementation actively underway but not yet complete." .

<https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_applicable> a owl:Class ;
    rdfs:label "not_applicable" ;
    rdfs:subClassOf iso27001:ImplementationStatus ;
    skos:definition "Control excluded from scope with documented justification per 6.1.3 d)." ;
    skos:note "Requires justification in Statement of Applicability" .

<https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#not_started> a owl:Class ;
    rdfs:label "not_started" ;
    rdfs:subClassOf iso27001:ImplementationStatus ;
    skos:definition "Control identified but no implementation activities begun." .

<https://w3id.org/lmodel/iso-iec-27001/ImplementationStatus#planned> a owl:Class ;
    rdfs:label "planned" ;
    rdfs:subClassOf iso27001:ImplementationStatus ;
    skos:definition "Control scheduled for implementation with defined timeline." .

