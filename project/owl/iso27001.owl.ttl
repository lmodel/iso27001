    rdfs:range xsd:string ;
    skos:definition "Source of the improvement opportunity." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:incident_category a owl:DatatypeProperty ;
    rdfs:label "incident_category" ;
    rdfs:range xsd:string ;
    skos:definition "Category of incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:incident_datetime a owl:DatatypeProperty ;
    rdfs:label "incident_datetime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date and time the incident occurred or was detected." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:incident_description a owl:DatatypeProperty ;
    rdfs:label "incident_description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:inclusion_justification a owl:DatatypeProperty ;
    rdfs:label "inclusion_justification" ;
    rdfs:range xsd:string ;
    skos:definition "Justification for including the control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "6.1.3 d)" .

iso27001:industry_sector a owl:DatatypeProperty ;
    rdfs:label "industry_sector" ;
    rdfs:range xsd:string ;
    skos:definition "Primary industry sector of the organization." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:information_security_policy a owl:ObjectProperty ;
    rdfs:label "information_security_policy" ;
    rdfs:range iso27001:InformationSecurityPolicy ;
    skos:definition "Reference to the information security policy." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "5.2" .

iso27001:inherent_risk_level a owl:ObjectProperty ;
    rdfs:label "inherent_risk_level" ;
    rdfs:range iso27001:RiskLevel ;
    skos:definition "Risk level before controls are applied." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:initial_assessment a owl:DatatypeProperty ;
    rdfs:label "initial_assessment" ;
    rdfs:range xsd:string ;
    skos:definition "Initial assessment of the event." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:interested_party_changes a owl:DatatypeProperty ;
    rdfs:label "interested_party_changes" ;
    rdfs:range xsd:string ;
    skos:definition "Changes in interested party requirements." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:iso27001_clause "9.3.2 c)" .

iso27001:is_applicable a owl:DatatypeProperty ;
    rdfs:label "is_applicable" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the control is applicable." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:isms_changes_required a owl:DatatypeProperty ;
    rdfs:label "isms_changes_required" ;
    rdfs:range xsd:string ;
    skos:definition "Changes to ISMS required as a result." ;
