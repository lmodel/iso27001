iso27001:methodology_used a owl:DatatypeProperty ;
    rdfs:label "methodology_used" ;
    rdfs:range xsd:string ;
    skos:definition "Specific methodology applied in this assessment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:metric_definition a owl:DatatypeProperty ;
    rdfs:label "metric_definition" ;
    rdfs:range xsd:string ;
