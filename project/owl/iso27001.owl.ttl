iso27001:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable name or title." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:next_assessment_date a owl:DatatypeProperty ;
    rdfs:label "next_assessment_date" ;
    rdfs:range xsd:date ;
    skos:definition "Planned date for next assessment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:next_review_date a owl:DatatypeProperty ;
    rdfs:label "next_review_date" ;
    rdfs:range xsd:date ;
    skos:definition "Planned date for next review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:nonconformity_description a owl:DatatypeProperty ;
    rdfs:label "nonconformity_description" ;
    rdfs:range xsd:string ;
