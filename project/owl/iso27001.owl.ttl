<https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#almost_certain> a owl:Class ;
    rdfs:label "almost_certain" ;
    rdfs:subClassOf iso27001:LikelihoodRating ;
    skos:definition "Expected to occur in most circumstances (> 80% probability)." ;
    iso27001:numeric_value "5" .

<https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#likely> a owl:Class ;
    rdfs:label "likely" ;
    rdfs:subClassOf iso27001:LikelihoodRating ;
    skos:definition "Probably will occur (50-80% probability)." ;
    iso27001:numeric_value "4" .

<https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#possible> a owl:Class ;
    rdfs:label "possible" ;
    rdfs:subClassOf iso27001:LikelihoodRating ;
    skos:definition "May occur at some point (20-50% probability)." ;
    iso27001:numeric_value "3" .

<https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#rare> a owl:Class ;
    rdfs:label "rare" ;
    rdfs:subClassOf iso27001:LikelihoodRating ;
    skos:definition "Highly unlikely to occur (< 5% probability)." ;
    iso27001:numeric_value "1" .

<https://w3id.org/lmodel/iso-iec-27001/LikelihoodRating#unlikely> a owl:Class ;
    rdfs:label "unlikely" ;
    rdfs:subClassOf iso27001:LikelihoodRating ;
    skos:definition "Not expected but possible (5-20% probability)." ;
    iso27001:numeric_value "2" .

