        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:assessment_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:assessor ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Risk ;
            owl:onProperty iso27001:risks_identified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:recommendations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:assessment_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:summary_findings ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:next_assessment_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assessor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:next_assessment_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:recommendations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:methodology_used ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:methodology_used ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:assessment_scope ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risks_identified ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assessment_scope ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:summary_findings ],
        iso27001:DocumentedInformation ;
    skos:definition "An instance of risk assessment performed per Clause 8.2, identifying and evaluating information security risks." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Performed at planned intervals or when significant changes occur",
        "Results must be retained as documented information" ;
    iso27001:iso27001_clause "8.2" .

iso27001:RiskAssessmentProcess a owl:Class ;
    rdfs:label "RiskAssessmentProcess" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assessment_frequency ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assessment_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:impact_scale ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:assessment_frequency ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:impact_scale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:assessment_frequency ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:assessment_methodology ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:impact_scale ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:trigger_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:assessment_methodology ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:likelihood_scale ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_acceptance_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:risk_matrix ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:risk_matrix ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:assessment_criteria ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_matrix ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:risk_acceptance_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:trigger_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:likelihood_scale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:assessment_methodology ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:risk_acceptance_criteria ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:likelihood_scale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:assessment_criteria ],
        iso27001:DocumentedInformation ;
    skos:definition "The documented risk assessment process per Clause 6.1.2, defining criteria and methodology for identifying, analyzing, and evaluating risks." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must ensure repeated assessments produce consistent, valid, comparable results",
        "Must establish risk acceptance criteria",
        "Retained as documented information per 6.1.2" ;
    iso27001:iso27001_clause "6.1.2" ;
    iso27001:mandatory "true" .

<https://w3id.org/lmodel/iso-iec-27001/RiskLevel#critical> a owl:Class ;
    rdfs:label "critical" ;
    rdfs:subClassOf iso27001:RiskLevel ;
    skos:definition "Severe risk threatening organizational objectives; requires immediate executive action and resource allocation." .

<https://w3id.org/lmodel/iso-iec-27001/RiskLevel#high> a owl:Class ;
    rdfs:label "high" ;
    rdfs:subClassOf iso27001:RiskLevel ;
    skos:definition "Significant risk requiring priority treatment and escalation." .

<https://w3id.org/lmodel/iso-iec-27001/RiskLevel#low> a owl:Class ;
    rdfs:label "low" ;
    rdfs:subClassOf iso27001:RiskLevel ;
    skos:definition "Minor risk manageable through routine procedures." .

<https://w3id.org/lmodel/iso-iec-27001/RiskLevel#medium> a owl:Class ;
    rdfs:label "medium" ;
    rdfs:subClassOf iso27001:RiskLevel ;
    skos:definition "Moderate risk requiring management attention and planned controls." .

<https://w3id.org/lmodel/iso-iec-27001/RiskLevel#very_low> a owl:Class ;
    rdfs:label "very_low" ;
    rdfs:subClassOf iso27001:RiskLevel ;
    skos:definition "Negligible risk requiring no immediate action." .

<https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#accept> a owl:Class ;
    rdfs:label "accept" ;
    rdfs:subClassOf iso27001:RiskTreatmentOption ;
    skos:altLabel "retain" ;
    skos:definition "Accept the risk without further treatment, within risk appetite. Requires risk owner approval." .

<https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#avoid> a owl:Class ;
    rdfs:label "avoid" ;
    rdfs:subClassOf iso27001:RiskTreatmentOption ;
    skos:altLabel "terminate" ;
    skos:definition "Eliminate the risk by removing the activity or asset that creates it." .

<https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#modify> a owl:Class ;
    rdfs:label "modify" ;
    rdfs:subClassOf iso27001:RiskTreatmentOption ;
    skos:altLabel "mitigate",
        "reduce" ;
    skos:definition "Apply controls to change the risk level (reduce likelihood or impact)." .

<https://w3id.org/lmodel/iso-iec-27001/RiskTreatmentOption#share> a owl:Class ;
    rdfs:label "share" ;
    rdfs:subClassOf iso27001:RiskTreatmentOption ;
    skos:altLabel "transfer" ;
    skos:definition "Transfer or share risk with external parties (e.g., insurance, outsourcing)." .

iso27001:RiskTreatmentProcess a owl:Class ;
    rdfs:label "RiskTreatmentProcess" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:approval_workflow ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:approval_workflow ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:approval_workflow ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:control_selection_criteria ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:treatment_options_guidance ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:control_selection_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:soa_template ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:treatment_options_guidance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:soa_template ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_selection_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:soa_template ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:treatment_options_guidance ],
        iso27001:DocumentedInformation ;
    skos:definition "The documented risk treatment process per Clause 6.1.3, defining how treatment options are selected and controls determined." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must compare controls with Annex A",
        "Must determine necessary controls",
        "Must produce Statement of Applicability",
        "Must select treatment options based on risk assessment results" ;
    iso27001:iso27001_clause "6.1.3" ;
    iso27001:mandatory "true" .

iso27001:SoAEntry a owl:Class ;
    rdfs:label "SoAEntry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:implementation_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:responsible_role ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:inclusion_justification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:is_applicable ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:responsible_role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:implementation_evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:exclusion_justification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:target_implementation_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:is_applicable ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:target_implementation_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Role ;
            owl:onProperty iso27001:responsible_role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:inclusion_justification ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:exclusion_justification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:implementation_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:implementation_evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty iso27001:is_applicable ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:target_implementation_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:control_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:exclusion_justification ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:implementation_evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:inclusion_justification ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:ImplementationStatus ;
            owl:onProperty iso27001:implementation_status ] ;
    skos:definition "A single entry in the Statement of Applicability, documenting the applicability and implementation status of one control." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Each Annex A control should have a corresponding SoA entry",
        "Exclusions require documented justification" .

iso27001:StatementOfApplicability a owl:Class ;
    rdfs:label "StatementOfApplicability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:last_review_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:last_review_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty iso27001:last_review_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:not_applicable_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SoAEntry ;
            owl:onProperty iso27001:soa_entries ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:unsignedShort ;
            owl:onProperty iso27001:total_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:approved_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:total_controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:not_applicable_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:unsignedShort ;
            owl:onProperty iso27001:implemented_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:implemented_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:planned_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:unsignedShort ;
            owl:onProperty iso27001:planned_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:approved_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:unsignedShort ;
            owl:onProperty iso27001:not_applicable_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:approved_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:soa_entries ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:planned_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:implemented_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:total_controls ],
        iso27001:DocumentedInformation ;
    skos:definition "The Statement of Applicability (SoA) per 6.1.3 d), listing necessary controls with justification and implementation status." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must contain justification for inclusion",
        "Must contain necessary controls from risk treatment",
        "Must justify exclusion of any Annex A controls",
        "Must state whether controls are implemented or not" ;
    iso27001:iso27001_clause "6.1.3 d)" ;
    iso27001:mandatory "true" .

iso27001:TopicSpecificPolicy a owl:Class ;
    rdfs:label "TopicSpecificPolicy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:topic_area ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:applicable_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:target_audience ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:topic_area ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:target_audience ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:parent_policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:target_audience ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:parent_policy ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:InformationSecurityPolicy ;
            owl:onProperty iso27001:parent_policy ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:SecurityControl ;
            owl:onProperty iso27001:applicable_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:topic_area ],
        iso27001:DocumentedInformation ;
    skos:definition "A policy addressing a specific information security topic, supporting the overarching information security policy." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Examples include access control policy, cryptography policy, backup policy",
        "Referenced throughout Annex A controls" ;
    iso27001:annex_a_reference "5.1" .

iso27001:action_items a owl:DatatypeProperty ;
    rdfs:label "action_items" ;
    rdfs:range xsd:string ;
    skos:definition "Action items from the review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:affected_cia a owl:DatatypeProperty ;
    rdfs:label "affected_cia" ;
    rdfs:range xsd:string ;
    skos:definition "CIA properties affected." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:affected_cia_properties a owl:DatatypeProperty ;
    rdfs:label "affected_cia_properties" ;
    rdfs:range xsd:string ;
    skos:definition "Which CIA properties are affected (confidentiality, integrity, availability)." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Per 6.1.2 c) 1) risks associated with loss of CIA" .

iso27001:applicable_assets a owl:DatatypeProperty ;
    rdfs:label "applicable_assets" ;
    rdfs:range xsd:string ;
    skos:definition "Asset types this control applies to." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:applicable_threats a owl:DatatypeProperty ;
    rdfs:label "applicable_threats" ;
    rdfs:range xsd:string ;
    skos:definition "Threats this control addresses." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:assigned_to a owl:DatatypeProperty ;
    rdfs:label "assigned_to" ;
    rdfs:range xsd:string ;
    skos:definition "Person(s) assigned to this role." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:attendees a owl:DatatypeProperty ;
    rdfs:label "attendees" ;
    rdfs:range xsd:string ;
    skos:definition "Attendees of the review." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:audit_criteria a owl:DatatypeProperty ;
    rdfs:label "audit_criteria" ;
    rdfs:range xsd:string ;
    skos:definition "Criteria against which audit is conducted." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:audit_objectives a owl:DatatypeProperty ;
    rdfs:label "audit_objectives" ;
    rdfs:range xsd:string ;
    skos:definition "Objectives of the audit." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:audit_team a owl:DatatypeProperty ;
    rdfs:label "audit_team" ;
    rdfs:range xsd:string ;
    skos:definition "Audit team members." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:auditee_representatives a owl:DatatypeProperty ;
    rdfs:label "auditee_representatives" ;
    rdfs:range xsd:string ;
    skos:definition "Representatives from audited areas." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:authorities a owl:DatatypeProperty ;
    rdfs:label "authorities" ;
    rdfs:range xsd:string ;
    skos:definition "Authorities granted to the role." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:awareness_topics a owl:DatatypeProperty ;
    rdfs:label "awareness_topics" ;
    rdfs:range xsd:string ;
    skos:definition "Topics covered in awareness program." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:commitment_statements a owl:DatatypeProperty ;
    rdfs:label "commitment_statements" ;
    rdfs:range xsd:string ;
    skos:definition "Statements of commitment included in the policy." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must include commitment to continual improvement per 5.2 d)",
        "Must include commitment to satisfy requirements per 5.2 c)" .

iso27001:communication_items a owl:ObjectProperty ;
    rdfs:label "communication_items" ;
    rdfs:range iso27001:CommunicationItem ;
    skos:definition "Communication items in the plan." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:competence_records a owl:ObjectProperty ;
    rdfs:label "competence_records" ;
    rdfs:range iso27001:CompetenceRecord ;
    skos:definition "Competence records for personnel." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:competency_gaps a owl:DatatypeProperty ;
    rdfs:label "competency_gaps" ;
    rdfs:range xsd:string ;
    skos:definition "Identified competency gaps." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:containment_actions a owl:DatatypeProperty ;
    rdfs:label "containment_actions" ;
    rdfs:range xsd:string ;
    skos:definition "Actions to contain the incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:context_external_issues a owl:DatatypeProperty ;
    rdfs:label "context_external_issues" ;
    rdfs:range xsd:string ;
    skos:definition "External issues relevant to ISMS per 4.1." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:context_internal_issues a owl:DatatypeProperty ;
    rdfs:label "context_internal_issues" ;
    rdfs:range xsd:string ;
    skos:definition "Internal issues relevant to ISMS per 4.1." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:control_measures a owl:DatatypeProperty ;
    rdfs:label "control_measures" ;
    rdfs:range xsd:string ;
    skos:definition "Control measures implemented." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:controls a owl:ObjectProperty ;
    rdfs:label "controls" ;
    rdfs:range iso27001:SecurityControl ;
    skos:definition "Security controls applied in the ISMS." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:controls_to_implement a owl:ObjectProperty ;
    rdfs:label "controls_to_implement" ;
    rdfs:range iso27001:SecurityControl ;
    skos:definition "Controls to be implemented as part of treatment." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

iso27001:corrective_actions a owl:ObjectProperty ;
    rdfs:label "corrective_actions" ;
    rdfs:range iso27001:CorrectiveAction ;
    skos:definition "Corrective actions." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> .

