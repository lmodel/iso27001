<https://w3id.org/lmodel/iso-iec-27001.owl.ttl> a owl:Ontology ;
    rdfs:label "iso27001" ;
    dcterms:license "https://creativecommons.org/licenses/by/4.0/" ;
    dcterms:title "ISO/IEC 27001:2022 Information Security Management System Schema" ;
    pav:version "1.0.0" ;
    skos:definition """A comprehensive LinkML schema modeling the requirements, clauses, and Annex A controls of ISO/IEC 27001:2022. Designed for open data publication, automated validation, and integration with governance, risk, and compliance (GRC) systems.
This schema captures: - ISMS lifecycle (establish, implement, maintain, improve) - Risk assessment and treatment processes (Clause 6.1) - All 93 Annex A controls organized by domain - Audit, measurement, and continual improvement artifacts""" ;
    iso27001:aligned_standard "ISO/IEC 27002:2022 (Annex A control guidance)" ;
    iso27001:normative_reference "ISO/IEC 27000 (vocabulary and overview)" ;
    iso27001:risk_framework_alignment "ISO 31000:2018" ;
    iso27001:schema_maintainer "noel.mcloughlin@gmail.com" ;
    iso27001:schema_status "stable" ;
    iso27001:standard_date "2022-10" ;
    iso27001:standard_edition "Third edition" ;
    iso27001:standard_reference "ISO/IEC 27001:2022(E)" ;
    iso27001:standard_title "Information security, cybersecurity and privacy protection —  Information security management systems — Requirements" .

iso27001:AuditProgramme a owl:Class ;
    rdfs:label "AuditProgramme" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:auditor_qualifications ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:audit_frequency_rationale ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:InternalAudit ;
            owl:onProperty iso27001:planned_audits ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:resource_requirements ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:programme_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:programme_period ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:audit_frequency_rationale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:auditor_qualifications ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:resource_requirements ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:planned_audits ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:programme_period ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:programme_period ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:auditor_qualifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:programme_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:programme_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:audit_frequency_rationale ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:resource_requirements ],
        iso27001:DocumentedInformation ;
    skos:definition "The internal audit programme per 9.2.2, planning audit activities over a defined period." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    skos:note "Must consider process importance and previous audit results",
        "Must define audit criteria and scope for each audit",
        "Must ensure auditor objectivity and impartiality" ;
    iso27001:iso27001_clause "9.2.2" .

iso27001:InformationSecurityEvent a owl:Class ;
    rdfs:label "InformationSecurityEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:categorized_as_incident ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:event_datetime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:initial_assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:event_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:linked_incident ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:linked_incident ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:reporter ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:event_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:affected_assets ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:InformationSecurityIncident ;
            owl:onProperty iso27001:linked_incident ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty iso27001:event_datetime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:reporter ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty iso27001:initial_assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:reporter ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty iso27001:categorized_as_incident ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty iso27001:categorized_as_incident ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:event_datetime ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:initial_assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom iso27001:Asset ;
            owl:onProperty iso27001:affected_assets ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty iso27001:event_description ],
        iso27001:NamedEntity ;
    skos:definition "An information security event per A.5.25, which may or may not be categorized as an incident." ;
    skos:inScheme <https://w3id.org/lmodel/iso-iec-27001> ;
    iso27001:annex_a_control "5.25" .

