            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the action." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:action_description ],
        [ sh:datatype xsd:string ;
            sh:description "Changes to ISMS required as a result." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:isms_changes_required ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:id ],
        [ sh:class iso27001:Nonconformity ;
            sh:description "Nonconformity this action addresses." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path iso27001:linked_nonconformity ],
        [ sh:datatype xsd:string ;
            sh:description "Current status of the document or entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:status ],
        [ sh:datatype xsd:string ;
            sh:description "Criteria for evaluating effectiveness." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:effectiveness_criteria ],
        [ sh:datatype xsd:date ;
            sh:description "Target date for completing the action." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:target_completion_date ],
        [ sh:datatype xsd:date ;
            sh:description "Actual date the action was completed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:actual_completion_date ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Party responsible for the activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:responsible_party ] ;
    sh:targetClass iso27001:CorrectiveAction .

iso27001:Risk a sh:NodeShape ;
    rdfs:comment "An identified information security risk that may affect information security properties within the ISMS scope." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path iso27001:id ],
        [ sh:class iso27001:Asset ;
            sh:description "Assets affected by this risk or incident." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path iso27001:affected_assets ],
        [ sh:description "Assessed impact if risk materializes." ;
            sh:in ( "negligible" "minor" "moderate" "major" "severe" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path iso27001:impact ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the vulnerability that could be exploited." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:vulnerability_description ],
        [ sh:class iso27001:RiskTreatmentPlan ;
            sh:description "Risk treatment plan addressing this risk." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path iso27001:related_treatment_plan ],
        [ sh:description "Risk level before controls are applied." ;
            sh:in ( "very_low" "low" "medium" "high" "critical" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path iso27001:inherent_risk_level ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:string ;
            sh:description "Person accountable for managing the risk." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:risk_owner ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path iso27001:description ],
        [ sh:description "Assessed likelihood of risk occurrence." ;
            sh:in ( "rare" "unlikely" "possible" "likely" "almost_certain" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path iso27001:likelihood ],
        [ sh:datatype xsd:string ;
            sh:description "Which CIA properties are affected (confidentiality, integrity, availability)." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:affected_cia_properties ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path iso27001:name ],
        [ sh:description "Selected treatment option for the risk." ;
            sh:in ( "modify" "accept" "avoid" "share" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path iso27001:risk_treatment_option ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the threat exploiting the vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:threat_description ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path iso27001:created_date ],
        [ sh:description "Risk level after controls are applied." ;
            sh:in ( "very_low" "low" "medium" "high" "critical" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path iso27001:residual_risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "Priority for treating this risk." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:treatment_priority ],
        [ sh:class iso27001:SecurityControl ;
            sh:description "Controls currently in place affecting this risk." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path iso27001:existing_controls ],
        [ sh:datatype xsd:string ;
            sh:description "Source or origin of the risk." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:risk_source ] ;
    sh:targetClass iso27001:Risk .

iso27001:Role a sh:NodeShape ;
    rdfs:comment "An information security role with defined responsibilities and authorities per Clause 5.3." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Responsibilities assigned to the role." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:responsibilities ],
        [ sh:datatype xsd:string ;
            sh:description "Category of the role." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:role_type ],
        [ sh:datatype xsd:string ;
            sh:description "Rules for delegating responsibilities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:delegation_rules ],
        [ sh:datatype xsd:string ;
            sh:description "To whom this role reports." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path iso27001:reporting_line ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:string ;
            sh:description "What the role is accountable for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:accountability ],
        [ sh:datatype xsd:string ;
            sh:description "Authorities granted to the role." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:authorities ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path iso27001:name ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:id ],
        [ sh:datatype xsd:string ;
            sh:description "Person(s) assigned to this role." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:assigned_to ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path iso27001:description ] ;
    sh:targetClass iso27001:Role .

iso27001:SecurityControl a sh:NodeShape ;
    rdfs:comment "A security control from Annex A of ISO/IEC 27001:2022, derived from ISO/IEC 27002:2022. Represents a measure that modifies risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path iso27001:name ],
        [ sh:description "Current implementation status." ;
            sh:in ( "not_started" "planned" "in_progress" "implemented" "not_applicable" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path iso27001:implementation_status ],
        [ sh:class iso27001:SecurityControl ;
            sh:description "Other controls related to this one." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path iso27001:related_controls ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path iso27001:id ],
        [ sh:datatype xsd:string ;
            sh:description "Control identifier from Annex A (e.g., 5.1, 8.24)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:control_id ;
            sh:pattern "^[5-8]\\.[0-9]{1,2}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Threats this control addresses." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path iso27001:applicable_threats ],
        [ sh:datatype xsd:string ;
            sh:description "Title of the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:control_title ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Organization-authored implementation notes for the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:implementation_guidance ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:string ;
            sh:description "Organization-authored control statement or external control summary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:control_text ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Rating of control effectiveness." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:effectiveness_rating ],
        [ sh:description "Domain category of the control." ;
            sh:in ( "organizational" "people" "physical" "technological" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path iso27001:control_category ],
        [ sh:datatype xsd:date ;
            sh:description "Date the control was implemented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:implementation_date ],
        [ sh:datatype xsd:date ;
            sh:description "Date the control was last tested." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:last_test_date ],
        [ sh:datatype xsd:string ;
            sh:description "References to evidence of implementation." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path iso27001:evidence_references ],
        [ sh:datatype xsd:string ;
            sh:description "Person responsible for the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path iso27001:control_owner ],
        [ sh:datatype xsd:string ;
            sh:description "Asset types this control applies to." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:applicable_assets ] ;
    sh:targetClass iso27001:SecurityControl .

