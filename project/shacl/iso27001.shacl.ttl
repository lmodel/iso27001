            sh:order 4 ;
            sh:path iso27001:measurement_method ],
        [ sh:datatype xsd:string ;
            sh:description "Plan for achieving the objective." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:action_plan ],
        [ sh:datatype xsd:string ;
