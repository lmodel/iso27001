@prefix iso27001: <https://w3id.org/lmodel/iso27001/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

iso27001:AuditProgramme a sh:NodeShape ;
    rdfs:comment "The internal audit programme per 9.2.2, planning audit activities over a defined period." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:string ;
            sh:description "Person who created the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path iso27001:author ],
        [ sh:datatype xsd:string ;
            sh:description "Required qualifications for auditors." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:auditor_qualifications ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path iso27001:name ],
        [ sh:class iso27001:InternalAudit ;
            sh:description "Audits planned in this programme." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path iso27001:planned_audits ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Current status of the programme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:programme_status ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Period covered by the audit programme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:programme_period ],
        [ sh:datatype xsd:string ;
            sh:description "Unique reference number for document control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:document_reference ],
        [ sh:description "Classification of the documented information." ;
            sh:in ( "policy" "procedure" "standard" "guideline" "record" "plan" "report" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path iso27001:document_type ],
        [ sh:datatype xsd:duration ;
            sh:description "Duration for which the document is retained." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path iso27001:retention_period ],
        [ sh:datatype xsd:string ;
            sh:description "Information classification level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path iso27001:classification ],
        [ sh:datatype xsd:string ;
            sh:description "Person who approved the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:approved_by ],
        [ sh:datatype xsd:string ;
            sh:description "Resource requirements for the programme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:resource_requirements ],
        [ sh:datatype xsd:string ;
            sh:description "Current status of the document or entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path iso27001:status ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the document is due for review." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path iso27001:review_date ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path iso27001:id ],
        [ sh:datatype xsd:string ;
            sh:description "Rationale for audit frequency decisions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:audit_frequency_rationale ],
        [ sh:datatype xsd:string ;
            sh:description "Person accountable for the document content and maintenance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path iso27001:owner ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the document was approved." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:approved_date ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the document becomes effective." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:effective_date ] ;
    sh:targetClass iso27001:AuditProgramme .

iso27001:InformationSecurityEvent a sh:NodeShape ;
    rdfs:comment "An information security event per A.5.25, which may or may not be categorized as an incident." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path iso27001:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Date and time of the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:event_datetime ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:version ],
        [ sh:class iso27001:Asset ;
            sh:description "Assets affected by this risk or incident." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path iso27001:affected_assets ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:event_description ],
        [ sh:class iso27001:InformationSecurityIncident ;
            sh:description "Linked incident if categorized." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path iso27001:linked_incident ],
        [ sh:datatype xsd:string ;
            sh:description "Person who reported the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:reporter ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the event was categorized as an incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:categorized_as_incident ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Initial assessment of the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:initial_assessment ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:id ] ;
    sh:targetClass iso27001:InformationSecurityEvent .

iso27001:InformationSecurityManagementSystem a sh:NodeShape ;
    rdfs:comment "Top-level container representing an organization's complete ISMS per ISO 27001. Aggregates all components required to support the full ISMS lifecycle." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class iso27001:InformationSecurityObjective ;
            sh:description "Information security objectives." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path iso27001:objectives ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path iso27001:description ],
        [ sh:class iso27001:Role ;
            sh:description "Information security roles defined in the ISMS." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path iso27001:roles ],
        [ sh:class iso27001:DocumentedInformation ;
            sh:description "Register of documented information." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path iso27001:documented_information_register ],
        [ sh:class iso27001:InterestedParty ;
            sh:description "Stakeholders relevant to the ISMS." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path iso27001:interested_parties ],
        [ sh:datatype xsd:date ;
            sh:description "Date recertification is due." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path iso27001:recertification_date ],
        [ sh:class iso27001:SecurityControl ;
            sh:description "Security controls applied in the ISMS." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path iso27001:controls ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path iso27001:id ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path iso27001:created_date ],
        [ sh:class iso27001:RiskTreatmentProcess ;
            sh:description "Reference to the risk treatment process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path iso27001:risk_treatment_process ],
        [ sh:class iso27001:ImprovementOpportunity ;
            sh:description "Improvement opportunities tracked." ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path iso27001:improvements ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path iso27001:modified_date ],
        [ sh:class iso27001:RiskAssessmentProcess ;
            sh:description "Reference to the risk assessment process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path iso27001:risk_assessment_process ],
        [ sh:class iso27001:MonitoringProgram ;
            sh:description "Reference to the monitoring program." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path iso27001:monitoring_program ],
        [ sh:class iso27001:CompetenceRecord ;
            sh:description "Competence records for personnel." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path iso27001:competence_records ],
        [ sh:class iso27001:InternalAudit ;
            sh:description "Internal audit instances." ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path iso27001:internal_audits ],
        [ sh:class iso27001:Nonconformity ;
            sh:description "Nonconformities identified." ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path iso27001:nonconformities ],
        [ sh:class iso27001:AwarenessProgram ;
            sh:description "Reference to the awareness program." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path iso27001:awareness_program ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path iso27001:name ],
        [ sh:class iso27001:StatementOfApplicability ;
            sh:description "Reference to the Statement of Applicability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path iso27001:statement_of_applicability ],
        [ sh:datatype xsd:string ;
            sh:description "External issues relevant to ISMS per 4.1." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:context_external_issues ],
        [ sh:class iso27001:RiskTreatmentPlan ;
            sh:description "Risk treatment plans." ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path iso27001:risk_treatment_plans ],
        [ sh:class iso27001:RiskAssessment ;
            sh:description "Risk assessment instances." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path iso27001:risk_assessments ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path iso27001:version ],
        [ sh:class iso27001:CommunicationPlan ;
            sh:description "Reference to the communication plan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path iso27001:communication_plan ],
        [ sh:datatype xsd:string ;
            sh:description "Defined boundaries of the ISMS scope." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:scope_boundaries ],
        [ sh:datatype xsd:string ;
            sh:description "Accredited certification body." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path iso27001:certification_body ],
        [ sh:datatype xsd:string ;
            sh:description "Documented statement of ISMS scope per 4.3." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:scope_statement ],
        [ sh:class iso27001:OperationalProcedure ;
            sh:description "Operational procedures." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path iso27001:operational_procedures ],
        [ sh:class iso27001:CorrectiveAction ;
            sh:description "Corrective actions." ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path iso27001:corrective_actions ],
        [ sh:datatype xsd:string ;
            sh:description "Current certification status." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path iso27001:certification_status ],
        [ sh:datatype xsd:string ;
            sh:description "Any exclusions from scope with justification." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:scope_exclusions ],
        [ sh:class iso27001:Resource ;
            sh:description "Resources provided for the ISMS." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path iso27001:resources ],
        [ sh:class iso27001:InformationSecurityPolicy ;
            sh:description "Reference to the information security policy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path iso27001:information_security_policy ],
        [ sh:class iso27001:Organization ;
            sh:description "Reference to the organization operating the ISMS." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path iso27001:organization ],
        [ sh:class iso27001:ManagementReview ;
            sh:description "Management review instances." ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path iso27001:management_reviews ],
        [ sh:datatype xsd:date ;
            sh:description "Date certification was achieved." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path iso27001:certification_date ],
        [ sh:datatype xsd:string ;
            sh:description "Internal issues relevant to ISMS per 4.1." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:context_internal_issues ] ;
    sh:targetClass iso27001:InformationSecurityManagementSystem .

iso27001:NamedEntity a sh:NodeShape ;
    rdfs:comment "Abstract base class for all entities with an identifier, name, and description. Provides common identification and documentation slots." ;
    sh:closed false ;
    sh:ignoredProperties ( iso27001:size_category iso27001:relationship iso27001:containment_actions iso27001:responsibilities iso27001:closure_status iso27001:implementation_date iso27001:retention_period iso27001:residual_risk_level iso27001:corrective_actions iso27001:cost iso27001:reporter iso27001:asset_owner iso27001:change_control_requirements iso27001:plan_scope iso27001:trading_names iso27001:controls iso27001:recovery_actions iso27001:completion_tracking iso27001:decisions iso27001:training_records iso27001:management_reviews iso27001:organization_type iso27001:soa_entries iso27001:initial_assessment iso27001:similar_nonconformities_check iso27001:approved_by iso27001:completion_date iso27001:assessment_date iso27001:residual_risk_acceptance iso27001:responsible_party iso27001:applicability_statement iso27001:effectiveness_criteria iso27001:interested_parties iso27001:next_review_date iso27001:severity iso27001:risk_treatment_process iso27001:resource_requirements iso27001:applicable_controls iso27001:likelihood_scale iso27001:risk_owner iso27001:expected_benefit iso27001:root_cause_addressed iso27001:control_selection_criteria iso27001:implementation_guidance iso27001:threat_description iso27001:audit_results_summary iso27001:action_items iso27001:risk_treatment_plans iso27001:delegation_rules iso27001:implementation_plan iso27001:actual_completion_date iso27001:assigned_to iso27001:context_external_issues iso27001:affected_cia_properties iso27001:legal_name iso27001:inherent_risk_level iso27001:measurement_method iso27001:reporting_line iso27001:identification_date iso27001:regulatory_jurisdictions iso27001:risk_assessments iso27001:awareness_topics iso27001:role_type iso27001:context_changes iso27001:communication_needs iso27001:priority iso27001:target_value iso27001:programme_status iso27001:related_treatment_plan iso27001:asset_type iso27001:existing_controls iso27001:experience_records iso27001:improvement_description iso27001:methodology_used iso27001:objective_statement iso27001:process_criteria iso27001:owner iso27001:implementation_timeline iso27001:finding_type iso27001:identified_by iso27001:policy_objectives_framework iso27001:applicable_threats iso27001:documented_information_register iso27001:certification_body iso27001:incident_datetime iso27001:competency_assessment_date iso27001:post_incident_review iso27001:implemented_count iso27001:target_audience iso27001:responsible_roles iso27001:audit_scope iso27001:roles iso27001:treatment_options_guidance iso27001:risk_owner_approval iso27001:notification_required iso27001:audit_type iso27001:author iso27001:lessons_learned iso27001:incident_category iso27001:responsible_parties iso27001:audit_team iso27001:root_cause_analysis iso27001:scope_exclusions iso27001:finding_description iso27001:document_reference iso27001:organization iso27001:action_plan iso27001:assessment_scope iso27001:education_records iso27001:resources iso27001:effectiveness_rating iso27001:development_actions iso27001:improvement_opportunities iso27001:current_value iso27001:control_id iso27001:allocation_date iso27001:criticality iso27001:controls_to_implement iso27001:status iso27001:scope_statement iso27001:employee_count iso27001:last_review_date iso27001:party_type iso27001:audit_reference iso27001:objective_evidence iso27001:consequences_addressed iso27001:findings iso27001:control_owner iso27001:treatment_priority iso27001:auditee_representatives iso27001:trigger_events iso27001:related_topic_policies iso27001:audit_plan iso27001:positive_observations iso27001:recertification_date iso27001:topic_area iso27001:closure_date iso27001:risk_matrix iso27001:performance_trends iso27001:outcome_assessment iso27001:quantity iso27001:planned_count iso27001:audit_period_start iso27001:policy_statement iso27001:closure_datetime iso27001:information_security_policy iso27001:competence_records iso27001:detection_method iso27001:closure_evidence iso27001:incident_description iso27001:affected_assets iso27001:eradication_actions iso27001:risks_addressed iso27001:person_name iso27001:accountability iso27001:awareness_program iso27001:assessment_criteria iso27001:risk_implication iso27001:control_text iso27001:assessment_frequency iso27001:target_date iso27001:linked_nonconformity iso27001:assessor iso27001:effective_date iso27001:internal_audits iso27001:effectiveness_measures iso27001:target_completion_date iso27001:parent_policy iso27001:risk_source iso27001:next_assessment_date iso27001:planned_audits iso27001:linked_corrective_action iso27001:objectives iso27001:auditor_qualifications iso27001:geographic_locations iso27001:effectiveness_review_date iso27001:implementation_status iso27001:measurement_frequency iso27001:approved_date iso27001:classification iso27001:operational_procedures iso27001:authorities iso27001:immediate_actions iso27001:review_date iso27001:summary_findings iso27001:auditee_response iso27001:procedure_scope iso27001:linked_incident iso27001:availability_status iso27001:requirement_violated iso27001:evidence_collected iso27001:frequency iso27001:nonconformity_description iso27001:audit_conclusion iso27001:person_role iso27001:industry_sector iso27001:nonconformities iso27001:monitoring_program iso27001:categorized_as_incident iso27001:response_actions iso27001:resource_type iso27001:interested_party_changes iso27001:programme_period iso27001:subsidiaries iso27001:risk_treatment_option iso27001:risks_identified iso27001:likelihood iso27001:acknowledgment_required iso27001:action_description iso27001:attendees iso27001:scope_boundaries iso27001:metric_definition iso27001:detection_date iso27001:climate_change_relevant iso27001:affected_cia iso27001:control_measures iso27001:risk_assessment_results iso27001:audit_frequency_rationale iso27001:impact_scale rdf:type iso27001:risk_acceptance_criteria iso27001:audit_period_end iso27001:required_competencies iso27001:communication_plan iso27001:recommended_action iso27001:contact_information iso27001:audit_objectives iso27001:linked_corrective_actions iso27001:certification_status iso27001:monitoring_items iso27001:soa_template iso27001:control_reference iso27001:impact iso27001:not_applicable_count iso27001:location iso27001:event_datetime iso27001:control_title iso27001:report_date iso27001:report_distribution iso27001:isms_changes_required iso27001:notifications_made iso27001:improvement_source iso27001:asset_custodian iso27001:resources_required iso27001:allocated_to iso27001:applicable_assets iso27001:certification_date iso27001:detected_by iso27001:improvements iso27001:root_cause iso27001:communication_items iso27001:lead_auditor iso27001:vulnerability_description iso27001:responsible_role iso27001:control_category iso27001:commitment_statements iso27001:last_test_date iso27001:treatment_actions iso27001:evidence_references iso27001:related_controls iso27001:audit_criteria iso27001:competency_gaps iso27001:risk_assessment_process iso27001:context_internal_issues iso27001:communication_date iso27001:achievement_status iso27001:event_description iso27001:total_controls iso27001:statement_of_applicability iso27001:document_type iso27001:clause_reference iso27001:delivery_methods iso27001:requirements iso27001:approval_workflow iso27001:previous_actions_status iso27001:related_risks iso27001:recommendations iso27001:nonconformity_source iso27001:assessment_methodology iso27001:parent_organization iso27001:effectiveness_verified ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:name ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
