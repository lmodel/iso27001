iso27001:InformationSecurityIncident a sh:NodeShape ;
    rdfs:comment "An information security incident per A.5.26, requiring response per documented procedures." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Detailed description of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path iso27001:description ],
        [ sh:datatype xsd:string ;
            sh:description "Evidence collected." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path iso27001:evidence_collected ],
        [ sh:datatype xsd:string ;
            sh:description "Actions taken in response." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path iso27001:response_actions ],
        [ sh:datatype xsd:string ;
            sh:description "Category of incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path iso27001:incident_category ],
        [ sh:datatype xsd:string ;
            sh:description "Root cause of the nonconformity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path iso27001:root_cause ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path iso27001:incident_description ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Date and time of incident closure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path iso27001:closure_datetime ],
        [ sh:datatype xsd:string ;
            sh:description "Post-incident review findings." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path iso27001:post_incident_review ],
        [ sh:datatype xsd:string ;
            sh:description "Actions to eradicate the cause." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path iso27001:eradication_actions ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path iso27001:modified_date ],
        [ sh:datatype xsd:string ;
            sh:description "Actions to recover normal operations." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path iso27001:recovery_actions ],
        [ sh:datatype xsd:date ;
            sh:description "Date when the entity was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path iso27001:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path iso27001:version ],
        [ sh:datatype xsd:string ;
            sh:description "Notifications that were made." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path iso27001:notifications_made ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path iso27001:name ],
        [ sh:datatype xsd:string ;
            sh:description "Lessons learned from the incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path iso27001:lessons_learned ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether notification to authorities/parties was required." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path iso27001:notification_required ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Unique identifier for this entity instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path iso27001:id ],
        [ sh:datatype xsd:string ;
            sh:description "Actions to contain the incident." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path iso27001:containment_actions ],
        [ sh:datatype xsd:string ;
            sh:description "How the incident was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path iso27001:detection_method ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Date and time the incident occurred or was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path iso27001:incident_datetime ],
        [ sh:datatype xsd:string ;
            sh:description "CIA properties affected." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path iso27001:affected_cia ],
        [ sh:datatype xsd:string ;
            sh:description "Severity rating." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path iso27001:severity ],
        [ sh:class iso27001:Asset ;
            sh:description "Assets affected by this risk or incident." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path iso27001:affected_assets ] ;
    sh:targetClass iso27001:InformationSecurityIncident .

iso27001:InformationSecurityObjective a sh:NodeShape ;
